{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "cut-2026",
	"main": "./src/worker.ts",
	"compatibility_date": "2026-02-24",
	"compatibility_flags": ["nodejs_compat"],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "cut-2026",
			// Run `wrangler d1 create cut-2026` and paste the real ID here for deploy
			"database_id": "9b1d1a04-cb52-4e84-99cb-4ed3d501c2a7",
		},
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "cut-r2",
		},
	],
	// Worker Loader for plugin sandboxing
	"worker_loaders": [
		{
			"binding": "LOADER",
		},
	],
}
