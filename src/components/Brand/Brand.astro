---
import { Image } from "astro:assets";
import logo from "../../assets/CUT - transparent.webp";
---

<a href="/" class="brand-row">
  <Image
    src={logo}
    alt="CUT"
    height={52}
    loading="eager"
  />
  <div class="brand-text">
    <div class="top">Centro Universitario</div>
    <div class="main">Tlacaélel</div>
  </div>
</a>

<style>
  .brand-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
  }

  .top {
    font-family: var(--sans);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--secondary-soft);
    line-height: 1;
  }

  .main {
    font-family: var(--serif);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--secondary);
    line-height: 1.2;
  }
</style>
