// ── COUNTDOWN ──
function tick() {
  const target = new Date('2026-05-18T09:00:00-06:00');
  const diff = target - new Date();
  const el = document.getElementById('countdown');
  if (!el) return;
  if (diff <= 0) {
    el.innerHTML = '<span style="font-family:var(--ser);font-style:italic;color:var(--cr);font-size:1.5rem;">¡El congreso está en curso!</span>';
    return;
  }
  const d = Math.floor(diff/86400000);
  const h = Math.floor((diff%86400000)/3600000);
  const m = Math.floor((diff%3600000)/60000);
  const s = Math.floor((diff%60000)/1000);
  const p = n => String(n).padStart(2,'0');
  el.innerHTML = `
    <div class="cd-item"><div class="cd-num">${d}</div><div class="cd-lbl">Días</div></div>
    <div class="cd-sep">:</div>
    <div class="cd-item"><div class="cd-num">${p(h)}</div><div class="cd-lbl">Horas</div></div>
    <div class="cd-sep">:</div>
    <div class="cd-item"><div class="cd-num">${p(m)}</div><div class="cd-lbl">Min</div></div>
    <div class="cd-sep">:</div>
    <div class="cd-item"><div class="cd-num">${p(s)}</div><div class="cd-lbl">Seg</div></div>`;
}

// ── SPEAKERS ──
function renderSpeakers() {
  const c = document.getElementById('spk-container');
  if (!c) return;
  const byDay = {1:[],2:[],3:[]};
  SPEAKERS.forEach(s => byDay[s.day].push(s));
  const dn = {1:'Lunes 18 de mayo',2:'Martes 19 de mayo',3:'Miércoles 20 de mayo'};
  let h = '';
  [1,2,3].forEach(day => {
    if (!byDay[day].length) return;
    h += `<div class="day-group"><div class="day-lbl">${dn[day]}</div><div class="speakers-grid">`;
    byDay[day].forEach(s => {
      h += `<div class="spk-card reveal">
        <div class="spk-time">${s.time} hrs</div>
        <div class="spk-name">${s.name}</div>
        ${s.inst ? `<div class="spk-inst">${s.inst}</div>` : ''}
        <div class="spk-talk">&ldquo;${s.talk}&rdquo;</div>
        <div class="spk-venue">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          ${s.venue}
        </div>
      </div>`;
    });
    h += `</div></div>`;
  });
  c.innerHTML = h;
  observeReveals();
}

// ── SCHEDULE ──
let activeDay = 1, activeDisc = 'todas';
const tv = t => { if(!t||t==='—') return 9999; const [hh,mm]=t.split(':').map(Number); return hh*60+(mm||0); };

function renderSchedule() {
  const tl = document.getElementById('timeline');
  if (!tl) return;
  let items = A.filter(a => a.d === activeDay);
  if (activeDisc !== 'todas') items = items.filter(a => a.disc === activeDisc);
  if (!items.length) { tl.innerHTML = '<div class="empty">No hay actividades para este filtro.</div>'; return; }
  items.sort((a,b) => tv(a.time)-tv(b.time));
  const groups = {};
  items.forEach(a => { const k=a.time||'—'; if(!groups[k]) groups[k]=[]; groups[k].push(a); });
  let h = '';
  Object.entries(groups).forEach(([time,acts]) => {
    h += `<div class="time-group"><div class="tg-head"><div class="tg-t">${time}</div><div class="tg-line"></div></div><div class="tg-cards">`;
    acts.forEach(a => {
      const di = DISC[a.disc]||{label:a.disc,color:'#555'};
      h += `<div class="acard">
        <div class="acard-bar" style="background:${di.color}"></div>
        <div class="acard-body">
          <div class="acard-title">${a.title}</div>
          <div class="acard-spk">${a.speaker}${a.inst?` · <em>${a.inst}</em>`:''}</div>
          <div class="acard-meta">
            <span class="acard-tag" style="background:${di.color}">${di.label}</span>
            ${a.venue?`<span class="acard-venue"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>${a.venue}</span>`:''}
          </div>
        </div>
      </div>`;
    });
    h += `</div></div>`;
  });
  tl.innerHTML = h;
}

// ── INTERSECTION OBSERVER ──
let io;
function observeReveals() {
  if (!io) {
    io = new IntersectionObserver(entries => {
      entries.forEach(e => { if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); }});
    }, { threshold:0.1, rootMargin:'0px 0px -40px 0px' });
  }
  document.querySelectorAll('.reveal:not(.in)').forEach(el => io.observe(el));
}

// ── INIT ──
document.addEventListener('DOMContentLoaded', () => {
  tick(); setInterval(tick, 1000);
  renderSpeakers();
  renderSchedule();
  observeReveals();

  window.addEventListener('scroll', () => {
    document.getElementById('nav').classList.toggle('scrolled', window.scrollY > 60);
  }, { passive:true });

  document.querySelectorAll('.day-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.day-tab').forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected','false'); });
      tab.classList.add('active'); tab.setAttribute('aria-selected','true');
      activeDay = +tab.dataset.day;
      renderSchedule();
    });
  });

  document.querySelectorAll('.pill').forEach(pill => {
    pill.addEventListener('click', () => {
      document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      activeDisc = pill.dataset.d;
      renderSchedule();
    });
  });
});
</script>

