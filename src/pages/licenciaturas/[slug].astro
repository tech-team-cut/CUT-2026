---
import { PortableText } from "emdash/ui";
import ProgramDetail from "../../layouts/ProgramDetail.astro";
import { SectionHeader } from "../../components/SectionHeader";
import { CurriculumGrid } from "../../components/CurriculumGrid";
import { Button } from "../../components/Button";
import { resolveEntryPage } from "../../utils/resolve-entry-page";

const result = await resolveEntryPage(
	"licenciaturas",
	Astro.params.slug,
	Astro.url.origin,
	(s) => `/licenciaturas/${s}`,
);
if (!result.found) return Astro.redirect("/404");
Astro.cache.set(result.cacheHint);
const { entry: program, seo, slug } = result;
---

<ProgramDetail
	title={seo.title}
	pageTitle={seo.ogTitle}
	description={seo.description}
	canonical={seo.canonical}
	collection="licenciaturas"
	entryId={program.id}
	{slug}
>
	<!-- Hero -->
	<section class="hero" slot="hero">
		<div class="container">
			<div class="hero-grid">
				<div class="hero-main">
					<span class="eyebrow">Programa Académico · Licenciatura</span>
					<h1 class="t-display-lg" style="margin-top: 1rem;" {...program.edit.title}>
						{program.data.title}
					</h1>
					{program.data.excerpt && (
						<p class="t-body-lg hero-lede" style="margin-top: 1.5rem;" {...program.edit.excerpt}>
							{program.data.excerpt}
						</p>
					)}
					<div class="hero-cta">
						<Button variant="primary" href="/estudio/convocatoria">Solicitar información</Button>
						<Button variant="outline" href="#plan-estudios">Ver plan de estudios</Button>
					</div>
				</div>
				<aside class="hero-aside">
					<div class="stat-row">
						<div class="stat">
							<div class="num">{program.data.duration?.split(' ')[0] || '9'}<sup>SEM</sup></div>
							<div class="lbl">Duración</div>
						</div>
						<div class="stat">
							<div class="num">Pres.</div>
							<div class="lbl">Modalidad</div>
						</div>
						<div class="stat">
							<div class="num">SEP</div>
							<div class="lbl">RVOE</div>
						</div>
					</div>
				</aside>
			</div>
		</div>
	</section>

	<!-- Content main -->
	<Fragment slot="content-main">
		<SectionHeader
			num="— 01"
			title="Sobre el programa."
			description="Formación académica con un enfoque humanista y compromiso social para el desarrollo regional."
		/>
		<div class="prose" {...program.edit.content}>
			<PortableText value={program.data.content} />
		</div>
		<blockquote class="pull-q" style="margin-top: 3rem;">
			"Nuestra misión es formar líderes capaces de transformar la administración pública con ética y eficiencia."
		</blockquote>
	</Fragment>

	<!-- Sidebar -->
	<div class="sidebar-card" slot="sidebar">
		<h3 class="t-headline-sm">¿Por qué estudiar {program.data.title} en CUT?</h3>
		<ul class="benefit-list">
			<li>Docentes con amplia experiencia en el sector.</li>
			<li>Plan de estudios actualizado y pertinente.</li>
			<li>Vinculación con organismos gubernamentales.</li>
			<li>Excelencia académica a costos accesibles.</li>
		</ul>
		<Button variant="primary" href="/estudio/convocatoria" className="w-full">
			Iniciar Proceso
		</Button>
	</div>

	<!-- Curriculum -->
	<Fragment slot="curriculum">
		{(program.data as any).curriculum?.semesters && (
			<section id="plan-estudios" class="section section--low">
				<div class="container">
					<SectionHeader
						num="— 02"
						title="Plan de estudios."
						description="Mapa curricular organizado por semestres, diseñado para una formación integral y progresiva."
					/>
					<CurriculumGrid curriculum={program.data.curriculum as any} />
				</div>
			</section>
		)}
	</Fragment>

	<!-- CTA -->
	<section class="cta-section" slot="cta">
		<div class="container">
			<div class="cta-grid">
				<div class="cta-content">
					<span class="eyebrow eyebrow--light">Inscripciones Abiertas</span>
					<h2 class="cta-title">Únete a nuestra <em>comunidad académica</em></h2>
					<p class="cta-copy">
						Estamos listos para recibirte. Inicia hoy tu camino profesional en una institución comprometida con tu futuro.
					</p>
					<Button variant="primary" href="/estudio/admision">Ver requisitos de admisión</Button>
				</div>
				<div class="key-dates">
					<div class="key-date">
						<div class="d">25<span>JUN</span></div>
						<div>
							<div class="kl">Examen de Admisión</div>
							<div class="kd">Sede Central · 09:00 hrs</div>
						</div>
					</div>
					<div class="key-date">
						<div class="d">15<span>JUL</span></div>
						<div>
							<div class="kl">Resultados</div>
							<div class="kd">Consulta en línea o en campus</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</ProgramDetail>

<style>
	.sidebar-card {
		background: var(--surface-bright);
		border: 1px solid var(--outline-soft);
		padding: 2.5rem 2rem;
		position: sticky;
		top: calc(84px + 4rem);
	}

	.benefit-list {
		margin: 1.5rem 0 2rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.benefit-list li {
		font-size: 0.9375rem;
		color: var(--tertiary);
		padding-left: 1.5rem;
		position: relative;
	}

	.benefit-list li::before {
		content: "•";
		color: var(--primary);
		position: absolute;
		left: 0;
		font-weight: bold;
	}

	.w-full {
		width: 100%;
		justify-content: center;
	}

	.prose {
		margin-top: 3rem;
	}

	@media (max-width: 1024px) {
		.sidebar-card {
			position: static;
		}
	}
</style>
