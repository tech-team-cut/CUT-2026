---
import { getEmDashEntry, getSeoMeta, decodeSlug, getSiteSettings } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import { resolveStarterSiteIdentity } from "../../utils/site-identity";
import { CurriculumGrid } from "../../components/CurriculumGrid";
import { SectionHeader } from "../../components/SectionHeader";
import { Eyebrow } from "../../components/Eyebrow";
import { Button } from "../../components/Button";
import { StatCard } from "../../components/StatCard";

const slug = decodeSlug(Astro.params.slug);

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: program, cacheHint } = await getEmDashEntry("maestrias", slug);

if (!program) {
	return Astro.redirect("/404");
}

Astro.cache.set(cacheHint);
const { siteTitle } = resolveStarterSiteIdentity(await getSiteSettings());

const seo = getSeoMeta(program, {
	siteTitle,
	siteUrl: Astro.url.origin,
	path: `/maestrias/${slug}`,
});

const chars = (program.data as any).characteristics;
const curriculum = (program.data as any).curriculum;
---

<Base
	title={seo.title}
	pageTitle={seo.ogTitle}
	description={seo.description}
	canonical={seo.canonical}
	content={{ collection: "maestrias", id: program.id, slug }}
>
	<div class="maestria-detail">

		<!-- Hero — dark, institutional -->
		<section class="hero-dark">
			<div class="container">
				<div class="hero-inner">
					<div class="hero-main">
						<Eyebrow dark>Programa de Posgrado · Maestría</Eyebrow>
						<h1 class="t-display-lg hero-title" {...program.edit.title}>
							{program.data.title}
						</h1>
						{program.data.excerpt && (
							<p class="t-body-lg hero-lede" {...program.edit.excerpt}>
								{program.data.excerpt}
							</p>
						)}
						<div class="hero-cta">
							<Button variant="primary" href="/estudio/convocatoria">
								Solicitar información
							</Button>
							<Button variant="dark-border" href="#plan-estudios">
								Ver plan de estudios
							</Button>
						</div>
					</div>

					<!-- Program stats from characteristics -->
					<aside class="stats-panel">
						<div class="stats-label">Datos del programa</div>
						<div class="stats-grid">
							{chars?.total_ciclos && (
								<StatCard value={String(chars.total_ciclos)} suffix="SEM" label="Semestres" />
							)}
							{chars?.creditos && (
								<StatCard value={String(chars.creditos)} label="Créditos" />
							)}
							{chars?.numero_horas && (
								<StatCard value={chars.numero_horas >= 1000 ? (chars.numero_horas / 1000).toFixed(1) + 'K' : String(chars.numero_horas)} label="Horas" />
							)}
							{chars?.total_asignaturas && (
								<StatCard value={String(chars.total_asignaturas)} label="Materias" />
							)}
						</div>
						{chars && (
							<dl class="chars-list">
								{chars.diseño_curricular && (
									<>
										<dt>Diseño curricular</dt>
										<dd>{chars.diseño_curricular}</dd>
									</>
								)}
								{chars.duracion_ciclo && (
									<>
										<dt>Duración por ciclo</dt>
										<dd>{chars.duracion_ciclo}</dd>
									</>
								)}
								{chars.carga_horaria_semanal && (
									<>
										<dt>Carga semanal</dt>
										<dd>{chars.carga_horaria_semanal} hrs</dd>
									</>
								)}
								<dt>Modalidad</dt>
								<dd>{program.data.modality}</dd>
							</dl>
						)}
					</aside>
				</div>
			</div>
		</section>

		<!-- Content — objetivo, perfiles, líneas -->
		<section class="section">
			<div class="container">
				<div class="content-grid">
					<div class="content-main">
						<SectionHeader
							num="— 01"
							title="Sobre el programa."
							description="Posgrado orientado a la investigación, la práctica profesional avanzada y la contribución al desarrollo institucional."
						/>
						<div class="prose" {...program.edit.content}>
							<PortableText value={program.data.content} />
						</div>
					</div>

					<aside class="content-sidebar">
						<div class="sidebar-card">
							<h3 class="t-headline-sm">¿Por qué este posgrado en CUT?</h3>
							<ul class="benefit-list">
								<li>Docentes activos en el campo profesional.</li>
								<li>Enfoque práctico con base teórica sólida.</li>
								<li>Infraestructura especializada para tu área.</li>
								<li>Excelencia académica a costos accesibles.</li>
							</ul>
							<Button variant="primary" href="/estudio/convocatoria" className="w-full">
								Iniciar proceso de admisión
							</Button>
						</div>

						<div class="accreditation-block">
							<div class="t-label-md" style="color: var(--secondary-soft); margin-bottom: 0.75rem;">Reconocimiento oficial</div>
							<div class="acred-row">
								<span class="acred-badge">SEP</span>
								<span class="acred-badge">RVOE</span>
							</div>
						</div>
					</aside>
				</div>
			</div>
		</section>

		<!-- Propedéutico callout -->
		{curriculum?.propedeutico && (
			<section class="section--propedeutico">
				<div class="container">
					<div class="proped-inner">
						<div class="proped-label t-label-md">Curso propedéutico</div>
						<p class="proped-text">{curriculum.propedeutico}</p>
					</div>
				</div>
			</section>
		)}

		<!-- Curriculum -->
		{curriculum?.semesters?.length > 0 && (
			<section id="plan-estudios" class="section section--low">
				<div class="container">
					<SectionHeader
						num="— 02"
						title="Plan de estudios."
						description="Mapa curricular por semestres, con progresión de fundamentos teóricos a práctica especializada."
					/>
					<CurriculumGrid curriculum={curriculum} />
				</div>
			</section>
		)}

		<!-- CTA -->
		<section class="cta-dark">
			<div class="container">
				<div class="cta-inner">
					<div>
						<div class="t-label-md cta-label">Inscripciones abiertas</div>
						<h2 class="t-display-md cta-title">Forma parte de nuestra <em>comunidad de posgrado</em></h2>
						<p class="t-body-lg cta-copy">
							Amplía tu formación profesional con un programa de excelencia académica, reconocido por la SEP y diseñado para el ejercicio avanzado de tu disciplina.
						</p>
						<div class="cta-actions">
							<Button variant="primary" href="/estudio/admision">
								Ver requisitos de admisión
							</Button>
							<Button variant="dark-border" href="/estudio/convocatoria">
								Convocatoria 2026
							</Button>
						</div>
					</div>
					<div class="cta-divider" aria-hidden="true"></div>
					<div class="cta-contact">
						<div class="t-label-md cta-label">Contacto</div>
						<p class="cta-contact-text">Centro Universitario Tlacaélel<br />www.cut.com.mx</p>
					</div>
				</div>
			</div>
		</section>

	</div>
</Base>

<style>
	/* ── Hero dark ── */
	.hero-dark {
		background: var(--secondary);
		color: #fff;
		padding-block: var(--section-pad);
		border-bottom: 1px solid rgba(255,255,255,0.08);
	}

	.hero-inner {
		display: grid;
		grid-template-columns: 1fr 340px;
		gap: 5rem;
		align-items: start;
	}

	.hero-title {
		color: #fff;
		margin-top: 1rem;
	}

	.hero-lede {
		color: rgba(255,255,255,0.7);
		margin-top: 1.25rem;
		max-width: 560px;
	}

	.hero-cta {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		margin-top: 2rem;
	}

	/* ── Stats panel ── */
	.stats-panel {
		border: 1px solid rgba(255,255,255,0.12);
		padding: 2rem;
		background: rgba(255,255,255,0.04);
		margin-top: 4rem;
	}

	.stats-label {
		font-family: var(--sans);
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: rgba(255,255,255,0.4);
		margin-bottom: 1.5rem;
	}

	.stats-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1px;
		background: rgba(255,255,255,0.08);
		border: 1px solid rgba(255,255,255,0.08);
		margin-bottom: 2rem;
	}

	/* Override StatCard for dark context */
	.stats-grid :global(.stat) {
		background: rgba(255,255,255,0.04);
		padding: 1.25rem 1rem;
	}

	.stats-grid :global(.num) {
		font-family: var(--serif);
		font-size: 1.75rem;
		font-weight: 600;
		color: #fff;
		line-height: 1;
	}

	.stats-grid :global(.num sup) {
		font-family: var(--mono);
		font-size: 0.6rem;
		letter-spacing: 0.08em;
		color: var(--primary);
		text-transform: uppercase;
		vertical-align: super;
		margin-left: 2px;
	}

	.stats-grid :global(.lbl) {
		font-size: 11px;
		font-weight: 500;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: rgba(255,255,255,0.45);
		margin-top: 0.4rem;
	}

	.chars-list {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 0.5rem 1.5rem;
		font-size: 0.8125rem;
		border-top: 1px solid rgba(255,255,255,0.08);
		padding-top: 1.5rem;
	}

	.chars-list dt {
		color: rgba(255,255,255,0.4);
		font-family: var(--sans);
		font-weight: 500;
		white-space: nowrap;
	}

	.chars-list dd {
		color: rgba(255,255,255,0.8);
		font-family: var(--sans);
		font-weight: 500;
	}

	/* ── Content section ── */
	.content-grid {
		display: grid;
		grid-template-columns: 1fr 320px;
		gap: 5rem;
		align-items: start;
	}

	.prose {
		margin-top: 3rem;
	}

	/* Portable text headings inside prose */
	.prose :global(h2) {
		font-family: var(--serif);
		font-size: 1.375rem;
		font-weight: 600;
		color: var(--secondary);
		margin-top: 2.5rem;
		margin-bottom: 1rem;
		padding-bottom: 0.5rem;
		border-bottom: 1px solid var(--outline-soft);
	}

	.prose :global(p) {
		font-size: 1rem;
		line-height: 1.75;
		color: var(--tertiary);
		margin-top: 1rem;
	}

	.prose :global(ul) {
		margin-top: 1rem;
		display: flex;
		flex-direction: column;
		gap: 0.625rem;
	}

	.prose :global(li) {
		font-size: 0.9375rem;
		color: var(--tertiary);
		padding-left: 1.5rem;
		position: relative;
		line-height: 1.6;
	}

	.prose :global(li::before) {
		content: "/";
		color: var(--primary);
		position: absolute;
		left: 0;
		font-weight: 600;
	}

	/* ── Sidebar ── */
	.sidebar-card {
		background: var(--surface-bright);
		border: 1px solid var(--outline-soft);
		padding: 2rem;
		position: sticky;
		top: 100px;
	}

	.benefit-list {
		margin: 1.5rem 0 2rem;
		display: flex;
		flex-direction: column;
		gap: 0.875rem;
	}

	.benefit-list li {
		font-size: 0.9rem;
		color: var(--tertiary);
		padding-left: 1.25rem;
		position: relative;
		line-height: 1.5;
	}

	.benefit-list li::before {
		content: "—";
		color: var(--primary);
		position: absolute;
		left: 0;
		font-weight: 500;
	}

	.w-full {
		width: 100%;
		justify-content: center;
	}

	.accreditation-block {
		margin-top: 1.5rem;
		padding: 1.5rem 2rem;
		border: 1px solid var(--outline-soft);
		background: var(--surface-low);
	}

	.acred-row {
		display: flex;
		gap: 0.75rem;
	}

	.acred-badge {
		font-family: var(--mono);
		font-size: 0.75rem;
		font-weight: 500;
		letter-spacing: 0.06em;
		color: var(--secondary);
		border: 1px solid var(--outline);
		padding: 0.25rem 0.75rem;
	}

	/* ── Propedéutico ── */
	.section--propedeutico {
		background: var(--surface-container);
		border-top: 1px solid var(--outline-soft);
		border-bottom: 1px solid var(--outline-soft);
		padding-block: 2.5rem;
	}

	.proped-inner {
		display: grid;
		grid-template-columns: 200px 1fr;
		gap: 3rem;
		align-items: center;
	}

	.proped-label {
		color: var(--secondary-soft);
		font-weight: 600;
	}

	.proped-text {
		font-size: 0.9375rem;
		color: var(--tertiary);
		line-height: 1.7;
	}

	/* ── CTA dark ── */
	.cta-dark {
		background: var(--secondary);
		padding-block: var(--section-pad);
	}

	.cta-inner {
		display: grid;
		grid-template-columns: 1fr auto 260px;
		gap: 4rem;
		align-items: center;
	}

	.cta-label {
		color: var(--primary);
		margin-bottom: 1rem;
	}

	.cta-title {
		color: #fff;
		margin-bottom: 1.25rem;
	}

	.cta-title em {
		font-style: italic;
		color: rgba(255,255,255,0.7);
	}

	.cta-copy {
		color: rgba(255,255,255,0.6);
		font-size: 1rem;
		margin-bottom: 2rem;
		max-width: 500px;
	}

	.cta-actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.cta-divider {
		width: 1px;
		height: 160px;
		background: rgba(255,255,255,0.1);
	}

	.cta-contact-text {
		font-size: 0.9375rem;
		color: rgba(255,255,255,0.6);
		line-height: 1.8;
		margin-top: 0.75rem;
	}

	/* ── Responsive ── */
	@media (max-width: 1024px) {
		.hero-inner,
		.content-grid {
			grid-template-columns: 1fr;
			gap: 3rem;
		}

		.stats-panel {
			margin-top: 0;
		}

		.sidebar-card {
			position: static;
		}

		.cta-inner {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.cta-divider {
			display: none;
		}

		.proped-inner {
			grid-template-columns: 1fr;
			gap: 1rem;
		}
	}
</style>
