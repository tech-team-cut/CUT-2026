---
import { getEmDashCollection, getSiteSettings } from "emdash";
import Base from "../../layouts/Base.astro";
import { resolveStarterSiteIdentity } from "../../utils/site-identity";
import { SectionHeader } from "../../components/SectionHeader";
import { ProgramCard } from "../../components/ProgramCard";
import { Button } from "../../components/Button";

const { entries: maestrias, cacheHint } = await getEmDashCollection("maestrias", {});
Astro.cache.set(cacheHint);

const { siteTitle } = resolveStarterSiteIdentity(await getSiteSettings());
---

<Base
	title={`Maestrías — ${siteTitle}`}
	description="Programas de posgrado orientados a la investigación y la práctica profesional avanzada."
>
	<!-- Hero dark -->
	<section class="hero-dark">
		<div class="container">
			<div class="page-hero">
				<div>
					<span class="eyebrow eyebrow--light">Posgrados · Maestrías</span>
					<h1 class="t-display-lg hero-title" style="margin-top:1rem;">Amplía tu<br/><em>formación profesional.</em></h1>
					<p class="t-body-lg hero-lede" style="margin-top:1.5rem;">
						Posgrados reconocidos por la SEP, orientados a la investigación y el ejercicio profesional avanzado.
					</p>
					<div style="display:flex;gap:1rem;flex-wrap:wrap;margin-top:2rem;">
						<Button variant="primary" href="/estudio/convocatoria">Solicitar información</Button>
						<Button variant="dark-border" href="/estudio/admision">Requisitos de admisión</Button>
					</div>
				</div>
				<div class="page-hero-meta">
					<div class="stat">
						<div class="num">{maestrias.length}</div>
						<div class="lbl">Maestrías</div>
					</div>
					<div class="stat">
						<div class="num">SEP</div>
						<div class="lbl">RVOE</div>
					</div>
					<div class="stat">
						<div class="num">Mod.</div>
						<div class="lbl">Modalidad</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Grid -->
	<section class="section section--low">
		<div class="container">
			<SectionHeader
				num="— 01"
				title="Programas de posgrado."
				description="Modalidad modular y mixta, desarrollo semestral."
			/>
			<div class="masters-grid" style="margin-top:0;">
				{maestrias.map((entry, i) => (
					<ProgramCard
						index={`M.${String(i + 1).padStart(2, "0")}`}
						title={entry.data.title}
						meta={`Maestría${entry.data.duration ? ` · ${entry.data.duration}` : ""}`}
						href={`/maestrias/${(entry as any).slug}`}
						variant="master"
					/>
				))}
			</div>
		</div>
	</section>

	<!-- CTA dark -->
	<section class="cta-dark">
		<div class="container">
			<div class="cta-inner">
				<div>
					<div class="t-label-md cta-eyebrow">Inscripciones abiertas</div>
					<h2 class="t-display-md cta-title">Forma parte de nuestra <em>comunidad de posgrado</em></h2>
					<p class="t-body-lg cta-copy">
						Excelencia académica reconocida por la SEP, diseñada para el ejercicio avanzado de tu disciplina.
					</p>
					<div style="display:flex;gap:1rem;flex-wrap:wrap;">
						<Button variant="primary" href="/estudio/admision">Ver requisitos de admisión</Button>
						<Button variant="dark-border" href="/estudio/convocatoria">Convocatoria 2026</Button>
					</div>
				</div>
				<div class="cta-divider" aria-hidden="true"></div>
				<div class="cta-contact">
					<div class="t-label-md cta-eyebrow">Contacto</div>
					<p class="cta-contact-text">Centro Universitario Tlacaélel<br />www.cut.com.mx</p>
				</div>
			</div>
		</div>
	</section>
</Base>

<style>
	/* ── Hero dark ── */
	.hero-dark {
		background: var(--secondary);
		color: #fff;
		padding-block: var(--section-pad);
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
	}

	.hero-title {
		color: #fff;
	}

	.hero-lede {
		color: rgba(255, 255, 255, 0.7);
		max-width: 36rem;
	}

	.page-hero {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 4rem;
		align-items: end;
	}

	.page-hero-meta {
		display: flex;
		gap: 2.5rem;
		align-items: flex-end;
		padding-bottom: 0.5rem;
	}

	/* Stats on dark background */
	.stat .num {
		color: #fff;
	}

	.stat .lbl {
		color: rgba(255, 255, 255, 0.5);
	}

	/* ── CTA dark ── */
	.cta-dark {
		background: var(--secondary);
		padding-block: var(--section-pad);
	}

	.cta-inner {
		display: grid;
		grid-template-columns: 1fr auto 260px;
		gap: 4rem;
		align-items: center;
	}

	.cta-eyebrow {
		color: var(--primary);
		margin-bottom: 1rem;
	}

	.cta-title {
		color: #fff;
		margin-bottom: 1.25rem;
	}

	.cta-title em {
		font-style: italic;
		color: rgba(255, 255, 255, 0.7);
	}

	.cta-copy {
		color: rgba(255, 255, 255, 0.6);
		font-size: 1rem;
		margin-bottom: 2rem;
		max-width: 500px;
	}

	.cta-divider {
		width: 1px;
		height: 160px;
		background: rgba(255, 255, 255, 0.1);
	}

	.cta-contact-text {
		font-size: 0.9375rem;
		color: rgba(255, 255, 255, 0.6);
		line-height: 1.8;
		margin-top: 0.75rem;
	}

	@media (max-width: 1024px) {
		.cta-inner {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.cta-divider {
			display: none;
		}
	}

	@media (max-width: 768px) {
		.page-hero {
			grid-template-columns: 1fr;
		}

		.page-hero-meta {
			display: none;
		}
	}
</style>
