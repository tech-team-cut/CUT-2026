---
import { getSiteSettings, getEmDashCollection } from "emdash";
import {
	EmDashHead,
	EmDashBodyStart,
	EmDashBodyEnd,
} from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import { resolveStarterSiteIdentity } from "../utils/site-identity";
import { Header } from "../components/Header";
import { AnnouncementModal } from "../components/AnnouncementModal";
import Footer from "./Footer.astro";
import "../styles/global.css";

interface Props {
	title: string;
	pageTitle?: string | null;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	/** Pass content reference for plugin page contributions on content pages */
	content?: { collection: string; id: string; slug?: string | null };
}

const { title, pageTitle, description, image, canonical, content } = Astro.props;
const { siteTitle, siteTagline, siteLogo } = resolveStarterSiteIdentity(await getSiteSettings());
const resolvedCanonical = canonical ?? Astro.url.href;
const resolvedImage = image ?? `${Astro.url.origin}/og-default.webp`;

const { entries: announcements } = await getEmDashCollection("announcements", {});
const now = new Date();
const activeAnnouncement = announcements.find((a) => {
	const start = a.data.start_date ? new Date(a.data.start_date as string) : null;
	const end   = a.data.end_date   ? new Date(a.data.end_date   as string) : null;
	return (!start || now >= start) && (!end || now <= end);
}) ?? null;
const fullTitle = title.includes(siteTitle) ? title : `${title} — ${siteTitle}`;
const pageDescription = description ?? siteTagline;

const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: "website",
	title: fullTitle,
	pageTitle: pageTitle ?? title,
	description: pageDescription,
	canonical: resolvedCanonical,
	image: resolvedImage,
	content,
	siteName: siteTitle,
});
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{fullTitle}</title>
		{pageDescription && <meta name="description" content={pageDescription} />}
		<link rel="canonical" href={resolvedCanonical} />
		<meta name="twitter:card" content={image ? "summary_large_image" : "summary"} />
		<meta name="twitter:title" content={fullTitle} />
		{pageDescription && <meta name="twitter:description" content={pageDescription} />}
		<EmDashHead page={pageCtx} />
		<link rel="icon" href="/favicon.ico" sizes="32x32" />
		<link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
		<link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="theme-color" content="#b21c3e" />
	</head>
	<body>
		<EmDashBodyStart page={pageCtx} />

		{activeAnnouncement && (
			<AnnouncementModal
				client:load
				id={activeAnnouncement.id}
				title={activeAnnouncement.data.title as string}
				ctaLabel={activeAnnouncement.data.cta_label as string | null}
				ctaHref={activeAnnouncement.data.cta_href as string | null}
				imageUrl={activeAnnouncement.data.image
					? `/_emdash/api/media/file/${(activeAnnouncement.data.image as any).meta?.storageKey}`
					: null}
				imageAlt={(activeAnnouncement.data.image as any)?.alt ?? null}
			/>
		)}

		<Header
			client:load
			navLinks={[
				{ label: 'Inicio', href: '/', active: Astro.url.pathname === '/' },
				{
					label: 'Estudio',
					active: Astro.url.pathname.startsWith('/licenciaturas') || Astro.url.pathname.startsWith('/maestrias') || Astro.url.pathname.startsWith('/ejercicio-profesional'),
					subLinks: [
						{ label: 'Licenciaturas', href: '/licenciaturas' },
						{ label: 'Maestrías', href: '/maestrias' },
						{ label: 'Ejercicio Profesional', href: '/ejercicio-profesional' },
					],
				},
				{ label: 'Noticias', href: '/posts', active: Astro.url.pathname.startsWith('/posts') },
				{
					label: 'Servicios escolares',
					active: Astro.url.pathname.startsWith('/servicios-escolares') || Astro.url.pathname === '/servicio-social' || Astro.url.pathname === '/control-escolar' || Astro.url.pathname === '/titulacion' || Astro.url.pathname === '/biblioteca',
					subLinks: [
						{ label: 'Trámites control escolar', href: '/control-escolar', active: Astro.url.pathname === '/control-escolar' },
						{ label: 'Titulación', href: '/titulacion', active: Astro.url.pathname === '/titulacion' },
						{ label: 'Servicio social', href: '/servicio-social', active: Astro.url.pathname === '/servicio-social' },
						{ label: 'Biblioteca', href: '/biblioteca', active: Astro.url.pathname === '/biblioteca' },
						{ label: 'Becas', href: '/servicios-escolares/becas' },
					],
				},
			]}
			ctaLabel="Convocatoria 2026"
			ctaHref="/convocatoria"
		/>

		<main>
			<slot />
		</main>

		<Footer />

		<EmDashBodyEnd page={pageCtx} />
	</body>
</html>
